# Headscale server URL (used as fallback when no cookie auth is present)
HEADSCALE_URL=http://localhost:8080
# Headscale API key (used as fallback when no cookie auth is present)
HEADSCALE_API_KEY=your-api-key-here
# Allow private/local URLs for the login form (set to "false" in production)
HEADSCALE_ALLOW_PRIVATE_URLS=true
